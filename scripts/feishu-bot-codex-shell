#!/usr/bin/env bash
set -euo pipefail

# Launch a tmux session named claude-<basename(cwd)> with the chosen
# agent CLI (codex by default, claude if requested) running inside.
# Idempotent: if the session exists, attaches instead.

if ! command -v tmux >/dev/null 2>&1; then
    echo "ERROR: tmux not installed. Install with: brew install tmux  (or apt install tmux)" >&2
    exit 1
fi

CWD="${1:-$PWD}"
shift || true

# Second arg (when present) is the resolved tmux session name from daemon.
# Backward-compat fallback to claude-<basename(cwd)>.
if [ "$#" -gt 0 ] && [[ "$1" == claude-* ]]; then
    NAME="$1"
    shift
else
    NAME="claude-$(basename "$CWD")"
fi

# Third arg = agent name ("codex" | "claude"). Default codex.
AGENT="codex"
if [ "$#" -gt 0 ] && { [ "$1" = "codex" ] || [ "$1" = "claude" ]; }; then
    AGENT="$1"
    shift
fi

if ! command -v "$AGENT" >/dev/null 2>&1; then
    if [ "$AGENT" = "codex" ]; then
        echo "ERROR: codex CLI not on PATH. See https://github.com/openai/codex" >&2
    else
        echo "ERROR: claude CLI not on PATH. See https://docs.claude.com/en/docs/claude-code" >&2
    fi
    exit 1
fi

cd "$CWD"

if tmux has-session -t "$NAME" 2>/dev/null; then
    if [ "$#" -gt 0 ]; then
        echo "NOTE: session $NAME already exists; attaching. Extra args ($*) ignored." >&2
    else
        echo "Attaching to existing tmux session: $NAME"
    fi
    exec tmux attach -t "$NAME"
else
    echo "Creating tmux session: $NAME ($AGENT $*)"
    exec tmux new-session -A -s "$NAME" -c "$CWD" "$AGENT" "$@"
fi
